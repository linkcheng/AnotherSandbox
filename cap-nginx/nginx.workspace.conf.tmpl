# AI 个人沙箱 P3 —— workspace cap-nginx 配置（Phase 5 auth_request 落地）
# 由 orchestrator envsubst 渲染后挂载到 cap-nginx 容器（见 docker-compose.workspace.yml.tmpl
# 的 ${WORKSPACE_NGINX_CONF} 挂载点）。envsubst 变量：${ORCHESTRATOR_URL} / ${WORKSPACE_ID} / ${AUTH_FAILURE_MODE}
#
# specs/003-sandbox-p3-launcher/contracts/trusted-headers.md, research.md R6
# 鉴权链：请求 → auth_request /_auth → Orchestrator /api/v1/verify?workspace=${WORKSPACE_ID}
#         → 回写 X-User-Id/X-Workspace-Id/X-Permissions → auth_request_set 捕获
#         → proxy_set_header 覆盖注入 cap-agent（防外部伪造）。
# fail-closed（FR-023）：Orchestrator 5xx/超时 → @auth_closed → 403。

map $http_upgrade $connection_upgrade {
    default upgrade;
    '' '';
}

server {
    listen 80 default_server;
    server_name _;
    client_max_body_size 2g;

    # ── auth_request 内部端点（不对外）──
    # 经共享网络 sandbox-launcher-net 直连 orchestrator（不依赖 host-gateway，更稳）
    location = /_auth {
        internal;
        proxy_pass ${ORCHESTRATOR_URL}/api/v1/verify?workspace=${WORKSPACE_ID};
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URI $request_uri;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-Workspace-Id $http_x_workspace_id;
    }

    # fail-closed 分支（AUTH_FAILURE_MODE=fail-closed 默认；fail-open 仅调试用）
    location @auth_closed {
        internal;
        return 403;
    }

    # ── /v1/ → cap-agent（鉴权 + 可信 header 透传）──
    location /v1/ {
        auth_request /_auth;
        auth_request_set $x_user_id $upstream_http_x_user_id;
        auth_request_set $x_workspace_id $upstream_http_x_workspace_id;
        auth_request_set $x_permissions $upstream_http_x_permissions;
        # 覆盖注入防伪造（客户端传的 X-User-Id 被丢弃，仅用 orchestrator 回写的）
        proxy_set_header X-User-Id $x_user_id;
        proxy_set_header X-Workspace-Id $x_workspace_id;
        proxy_set_header X-Permissions $x_permissions;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_buffering off;
        proxy_pass http://cap-agent:9000;
        # fail-closed：orchestrator 5xx/超时 → 403（非穿透）
        error_page 500 502 503 504 = @auth_closed;
    }

    # ── /gui/ → cap-agent（同鉴权链，UI 资源）──
    location /gui/ {
        auth_request /_auth;
        auth_request_set $x_user_id $upstream_http_x_user_id;
        auth_request_set $x_workspace_id $upstream_http_x_workspace_id;
        proxy_set_header X-User-Id $x_user_id;
        proxy_set_header X-Workspace-Id $x_workspace_id;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_buffering off;
        proxy_pass http://cap-agent:9000;
        error_page 500 502 503 504 = @auth_closed;
    }

    # noVNC（cap-browser:6080）/ terminal（cap-terminal:7681）经 auth_request + WebSocket
    # 透传（FR-022 长连接核心）。code-server/jupyter 按需扩展，模式相同。

    location /novnc/ {
        auth_request /_auth;
        auth_request_set $x_user_id $upstream_http_x_user_id;
        proxy_set_header X-User-Id $x_user_id;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_buffering off;
        proxy_pass http://cap-browser:6080;
        error_page 500 502 503 504 = @auth_closed;
    }

    location /terminal/ {
        auth_request /_auth;
        auth_request_set $x_user_id $upstream_http_x_user_id;
        proxy_set_header X-User-Id $x_user_id;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_buffering off;
        proxy_pass http://cap-terminal:7681;
        error_page 500 502 503 504 = @auth_closed;
    }

    # /v1/health 经 cap-agent，但因 auth_request 公开路径由 cap-agent 中间件 PUBLIC_PATHS 放行；
    # workspace 外部探活仍需 auth_request（未认证 → 401）。
}
