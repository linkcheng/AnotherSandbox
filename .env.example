# AI 个人沙箱 P1 配置
# 复制到 .env 后修改

# 对外端口（默认 80；冲突时改 8080）
PORT=80

# Workspace 目录（宿主机路径，bind mount 到 /workspace）
WORKSPACE_DIR=${HOME}/sandbox-workspace

# Python 与 Node 版本
PYTHON_VERSION=3.12
NODE_VERSION=24

# 鉴权模式（P1 固定 none）
AUTH_MODE=none

# Docker Compose 项目名（默认 sandbox）
COMPOSE_PROJECT_NAME=sandbox

# ─── P2 Orchestrator（specs/002-sandbox-p2-orchestrator）───
# Orchestrator 服务端口
ORCH_PORT=8000
# PostgreSQL（Orchestrator 元数据库）
POSTGRES_PASSWORD=orchestrator
# JWT 签名密钥（生产必填；留空则开发态随机生成并告警）
JWT_SECRET_KEY=
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
# Workspace 对外端口分配范围（每 workspace 占 1 个，仅 cap-nginx）
WORKSPACE_PORT_START=8100
WORKSPACE_PORT_END=8199
# Workspace 软删除保留期（天后硬删；0=立即硬删，CI 用）
WORKSPACE_RETENTION_DAYS=7
# auth_request 降级策略（fail-closed 安全优先 / fail-open 仅调试）
AUTH_FAILURE_MODE=fail-closed
# Workspace Profile 卷根目录（宿主机）
WORKSPACE_VOLUME_ROOT=/tmp/sandbox-workspaces

# ─── P3 Launcher + Orchestrator-as-controller（specs/003-sandbox-p3-launcher）───
# Launcher 对外端口（单入口，托管 SPA + 反代 /api 与 /ws/<slug>/）
LAUNCHER_PORT=8080
# compose_runner 的 cwd（容器内挂载点；orchestrator 容器挂仓库根到 /workspace-compose）
# 仅 orchestrator 容器内生效，宿主机无需设置
WORKSPACE_COMPOSE_CWD=/workspace-compose

# ─── P3 OAuth（US1，社交登录；本批次预留，实现见后续批次）───
# OAuth 凭证仅后端 env，不进前端构建（FR-007）
OAUTH_MOCK=true
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# OAuth 回调地址（launcher 反代 /api 到 orchestrator）
OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth
