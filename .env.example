# AI 个人沙箱 P1 配置
# 复制到 .env 后修改

# 对外端口（默认 80；冲突时改 8080）
PORT=80

# Workspace 目录（宿主机路径，bind mount 到 /workspace）
WORKSPACE_DIR=${HOME}/sandbox-workspace

# Python 与 Node 版本
PYTHON_VERSION=3.12
NODE_VERSION=24

# 鉴权模式（P1 固定 none）
AUTH_MODE=none

# Docker Compose 项目名（默认 sandbox）
COMPOSE_PROJECT_NAME=sandbox

# ─── P2 Orchestrator（specs/002-sandbox-p2-orchestrator）───
# Orchestrator 服务端口
ORCH_PORT=8000
# PostgreSQL（Orchestrator 元数据库）
POSTGRES_PASSWORD=orchestrator
# JWT 签名密钥（生产必填；留空则开发态随机生成并告警）
JWT_SECRET_KEY=
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
# Workspace 对外端口分配范围（每 workspace 占 1 个，仅 cap-nginx）
WORKSPACE_PORT_START=8100
WORKSPACE_PORT_END=8199
# Workspace 软删除保留期（天后硬删；0=立即硬删，CI 用）
WORKSPACE_RETENTION_DAYS=7
# auth_request 降级策略（fail-closed 安全优先 / fail-open 仅调试）
AUTH_FAILURE_MODE=fail-closed
# Workspace Profile 卷根目录（宿主机）
WORKSPACE_VOLUME_ROOT=/tmp/sandbox-workspaces
