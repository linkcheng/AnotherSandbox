# AI 个人沙箱 P1 配置
# 复制到 .env 后修改

# 对外端口（默认 80；冲突时改 8080）
PORT=80

# Workspace 目录（宿主机路径，bind mount 到 /workspace）
WORKSPACE_DIR=${HOME}/sandbox-workspace

# Python 与 Node 版本
PYTHON_VERSION=3.12
NODE_VERSION=24

# 鉴权模式（P1 固定 none）
AUTH_MODE=none

# Docker Compose 项目名（默认 sandbox）
COMPOSE_PROJECT_NAME=sandbox
